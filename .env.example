# ==============================================================================
# TTPU CRM — MARKAZLASHGAN MUHIT O'ZGARUVCHILARI (namuna)
# ------------------------------------------------------------------------------
# Bu YAGONA muhit faylidir. Barcha servislar shundan o'qiydi:
#   - server (Django)      -> docker-compose env_file: ./.env
#   - bot2 (Telegram bot)  -> docker-compose env_file: ./.env
#   - followup_cron        -> docker-compose env_file: ./.env
#   - dashboard (Next.js)  -> NEXT_PUBLIC_API_URL build-arg (./.env dan)
#   - db (Postgres)        -> POSTGRES_* (compose interpolatsiyasi)
# Local (docker'siz) dev: load_dotenv(find_dotenv()) shu faylni yuqoriga qarab topadi.
#
# Foydalanish:  cp .env.example .env   va qiymatlarni to'ldiring.
# `.env` git'ga tushmaydi (gitignore). `.env.example` commit qilinadi (sirlarsiz).
# ==============================================================================

# ===== Django / Server =========================================================
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:3000
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7
ACCESS_COOKIE_NAME=access_token
REFRESH_COOKIE_NAME=refresh_token
JWT_COOKIE_SECURE=0
JWT_COOKIE_SAMESITE=Lax
JWT_COOKIE_DOMAIN=
CORS_ALLOWED_ORIGINS=http://localhost:3000
GUNICORN_BIND=0.0.0.0:8000
TIME_ZONE=UTC
ACCESS_LINK_TTL_DAYS=30

# ===== Ma'lumotlar bazasi (Postgres) ===========================================
# POSTGRES_* compose tomonidan db servisini yaratish uchun ham ishlatiladi.
USE_SQLITE=0
POSTGRES_DB=crm_server
POSTGRES_USER=crm_user
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_CONN_MAX_AGE=60

# ===== Servis tokenlari / integratsiya =========================================
# Bot2 server bilan SERVICE_TOKEN orqali gaplashadi. Server faqat uning
# SHA-256 hash'ini saqlaydi. Quyidagilar mos kelishi SHART:
#   SERVICE_TOKEN_BOT2_HASH == sha256(SERVICE_TOKEN)
# Hash:  python -c "import hashlib,sys; print(hashlib.sha256(sys.argv[1].encode()).hexdigest())" "<token>"
SERVICE_TOKEN_BOT2_HASH=
TELEGRAM_BOT_TOKEN=
AI_SERVICE_URL=
AI_SERVICE_TIMEOUT=30

# ===== Xavfsizlik (HTTPS/proksi — prod'da yoqiladi) ============================
USE_X_FORWARDED_HOST=0
SECURE_PROXY_SSL_HEADER_ENABLED=0
SECURE_SSL_REDIRECT=0
SESSION_COOKIE_SECURE=0
CSRF_COOKIE_SECURE=0
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=0
SECURE_HSTS_PRELOAD=0
SECURE_REFERRER_POLICY=same-origin

# ===== Bot2 service (Telegram bot) =============================================
BOT_TOKEN=123456:telegram-bot-tokeningiz
SERVER_BASE_URL=http://server:8000
SERVICE_TOKEN=raw-bot2-service-token   # sha256'i SERVICE_TOKEN_BOT2_HASH ga teng bo'lsin
DEFAULT_LANGUAGE=uz

# ===== Dashboard (Next.js — build-time, brauzerga ko'rinadi) ===================
NEXT_PUBLIC_API_URL=http://localhost:9006

# ===== AI hujjat tekshiruvi (Gemini) ===========================================
# Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
